@startuml
!pragma charset UTF-8
skinparam defaultFontName "Segoe UI"
!include <C4/C4_Container>

title Диаграмма контейнеров - Архитектура микросервисов CinemaAbyss

Person(user, "Пользователь", "Любитель кино")
System_Ext(payment_systems, "Платежные системы", "Внешние платежные процессоры")
System_Ext(recommendation_system, "Рекомендательная система", "ML-рекомендации")
System_Ext(content_providers, "Поставщики контента", "Внешние стриминговые сервисы")
System_Ext(rabbitmq, "RabbitMQ", "Система очередей сообщений")
System_Ext(s3_storage, "S3 Хранилище", "Объектное хранилище файлов")

Container(mobile_app, "Мобильное приложение", "React Native", "Клиент для смартфонов")
Container(web_app, "Веб-приложение", "React SPA", "Клиент для браузеров")
Container(smart_tv_app, "Smart TV приложение", "Custom TV OS", "Клиент для телевизоров")

System_Boundary(cinema_system, "Платформа CinemaAbyss") {

    Container(api_gateway, "API Gateway", "Go", "Маршрутизация запросов")

    Container(user_service, "Сервис пользователей", "Go", "Регистрация и аутентификация")
    Container(movies_service, "Сервис фильмов", "Go", "Метаданные и поиск фильмов")
    Container(payment_service, "Сервис платежей", "Go", "Обработка платежей")
    Container(subscription_service, "Сервис подписок", "Go", "Управление подписками")
    Container(events_service, "Сервис событий", "Go", "Обработка событий")

    Container(monolith, "Монолит", "Go", "Унаследованное приложение")

    ContainerDb(postgres, "PostgreSQL", "PostgreSQL 14", "База данных")
    Container(kafka, "Apache Kafka", "Kafka 2.7", "Очереди сообщений")
    Container(kafka_ui, "Kafka UI", "Web UI", "Мониторинг Kafka")

    Container(prometheus, "Prometheus", "Мониторинг", "Сбор метрик")
    Container(grafana, "Grafana", "Визуализация", "Дашборды")
}

System_Boundary(infrastructure, "Инфраструктура и DevOps") {
    Container(k8s_cluster, "Kubernetes", "K8s", "Оркестрация контейнеров")
    Container(helm, "Helm", "Helm", "Менеджер пакетов")
    Container(ci_cd, "CI/CD", "GitHub Actions", "Автоматизация развертывания")
    Container(docker_registry, "Docker Registry", "GitHub Registry", "Хранилище образов")
}

' Взаимодействие пользователей
Rel(user, mobile_app, "Использует", "HTTPS")
Rel(user, web_app, "Использует", "HTTPS")
Rel(user, smart_tv_app, "Использует", "HTTPS")

' Клиенты к API Gateway
Rel(mobile_app, api_gateway, "API вызовы", "REST")
Rel(web_app, api_gateway, "API вызовы", "REST")
Rel(smart_tv_app, api_gateway, "API вызовы", "REST")

' Маршрутизация API Gateway
Rel(api_gateway, user_service, "Запросы пользователей", "REST")
Rel(api_gateway, movies_service, "Запросы фильмов", "REST")
Rel(api_gateway, payment_service, "Запросы платежей", "REST")
Rel(api_gateway, subscription_service, "Запросы подписок", "REST")
Rel(api_gateway, monolith, "Запросы монолита", "REST")

' Работа с базой данных
Rel(user_service, postgres, "Данные пользователей", "SQL")
Rel(movies_service, postgres, "Данные фильмов", "SQL")
Rel(payment_service, postgres, "Данные платежей", "SQL")
Rel(subscription_service, postgres, "Данные подписок", "SQL")
Rel(monolith, postgres, "Данные монолита", "SQL")

' Обмен событиями
Rel(user_service, kafka, "События пользователей", "Kafka")
Rel(movies_service, kafka, "События фильмов", "Kafka")
Rel(payment_service, kafka, "События платежей", "Kafka")
Rel(subscription_service, kafka, "События подписок", "Kafka")
Rel(events_service, kafka, "Обработка событий", "Kafka")

' Мониторинг Kafka
Rel(kafka_ui, kafka, "Мониторинг", "Admin API")

' Сбор метрик
Rel(prometheus, user_service, "Метрики", "HTTP")
Rel(prometheus, movies_service, "Метрики", "HTTP")
Rel(prometheus, payment_service, "Метрики", "HTTP")
Rel(prometheus, subscription_service, "Метрики", "HTTP")
Rel(prometheus, events_service, "Метрики", "HTTP")
Rel(prometheus, monolith, "Метрики", "HTTP")
Rel(prometheus, kafka, "Метрики", "HTTP")
Rel(prometheus, postgres, "Метрики", "HTTP")
Rel(grafana, prometheus, "Запросы метрик", "HTTP")

' Внешние интеграции
Rel(payment_service, payment_systems, "Обработка платежей", "API")
Rel(movies_service, recommendation_system, "Рекомендации", "API")
Rel(movies_service, content_providers, "Метаданные", "API")
Rel(events_service, rabbitmq, "Сообщения", "AMQP")
Rel(movies_service, s3_storage, "Медиафайлы", "S3 API")

' Инфраструктура
Rel(k8s_cluster, user_service, "Оркестрация", "K8s")
Rel(k8s_cluster, movies_service, "Оркестрация", "K8s")
Rel(k8s_cluster, payment_service, "Оркестрация", "K8s")
Rel(k8s_cluster, subscription_service, "Оркестрация", "K8s")
Rel(k8s_cluster, events_service, "Оркестрация", "K8s")
Rel(k8s_cluster, api_gateway, "Оркестрация", "K8s")
Rel(k8s_cluster, postgres, "Оркестрация", "K8s")
Rel(k8s_cluster, kafka, "Оркестрация", "K8s")
Rel(k8s_cluster, prometheus, "Оркестрация", "K8s")
Rel(k8s_cluster, grafana, "Оркестрация", "K8s")

Rel(helm, k8s_cluster, "Развертывание", "K8s")
Rel(ci_cd, docker_registry, "Загрузка образов", "Docker")
Rel(k8s_cluster, docker_registry, "Скачивание образов", "Docker")

@enduml