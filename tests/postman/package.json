{
  "name": "cinemaabyss-api-tests",
  "version": "1.0.0",
  "description": "API tests for CinemaAbyss microservices architecture",
  "main": "run-tests.js",
  "scripts": {
    "test": "node run-tests.js",
    "test:local": "node run-tests.js --environment local",
    "test:docker": "node run-tests.js --environment docker",
    "test:kubernetes": "npm run setup:k8s && node run-tests.js --environment kubernetes",
    "test:k8s-ingress": "npm run setup:k8s && node run-kubernetes-tests.js",
    "setup:k8s": "..\\..\\scripts\\setup-kubernetes-tests.bat",
    "setup:k8s-linux": "bash ../../scripts/setup-kubernetes-tests.sh",
    "update:collection": "node update-collection.js"
  },
  "keywords": [
    "postman",
    "newman",
    "api",
    "testing",
    "microservices"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "newman": "^5.3.2",
    "yargs": "^17.6.2"
  }
}